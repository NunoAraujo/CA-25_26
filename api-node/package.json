{
  "name": "journaling-app-api",
  "version": "0.1.0",
  "description": "Node.js REST API for audio journaling platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --esm src/index.ts",
    "dev:watch": "nodemon --exec ts-node --esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "ts-node --esm prisma/seed.ts",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["journaling", "emotion", "audio"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.8.0",
    "express": "4.18.2",
    "typescript": "5.3.3",
    "helmet": "7.1.0",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "joi": "17.11.0",
    "pino": "8.17.2",
    "pino-pretty": "10.3.1",
    "uuid": "9.0.1",
    "multer": "1.4.5-lts.1",
    "bull": "4.11.5",
    "ioredis": "5.3.2",
    "node-cron": "3.0.2",
    "axios": "1.6.2",
    "jsonwebtoken": "9.1.2",
    "bcrypt": "5.1.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.10.6",
    "@types/jest": "29.5.11",
    "@types/multer": "1.4.11",
    "ts-node": "10.9.2",
    "nodemon": "3.0.2",
    "prisma": "5.8.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "supertest": "6.3.3",
    "@types/supertest": "2.0.12",
    "eslint": "8.56.0"
  }
}
