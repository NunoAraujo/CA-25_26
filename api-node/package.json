{
  "name": "journaling-app-api",
  "version": "0.1.0",
  "description": "Node.js REST API for audio journaling platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --esm src/index.ts",
    "dev:watch": "nodemon --exec ts-node --esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "ts-node --esm prisma/seed.ts",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["journaling", "emotion", "audio"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "express": "^4.18.0",
    "typescript": "^5.3.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.0",
    "dotenv": "^16.0.0",
    "joi": "^17.0.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.2.0",
    "uuid": "^9.0.0",
    "multer": "^1.4.0",
    "bull": "^4.11.0",
    "ioredis": "^5.3.0",
    "node-cron": "^3.0.0",
    "axios": "^1.6.0",
    "jsonwebtoken": "^9.1.0",
    "bcrypt": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "@types/multer": "^1.4.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.0.0",
    "prisma": "^5.8.0",
    "@prisma/cli": "^5.8.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "supertest": "^6.0.0",
    "@types/supertest": "^2.0.0",
    "eslint": "^8.56.0"
  }
}
