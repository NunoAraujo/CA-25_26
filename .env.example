# ==============================================================================
# Frontend Environment
# ==============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_ENV=development

# ==============================================================================
# Core Application Environment
# ==============================================================================
NODE_ENV=development
PORT=3000
JWT_SECRET=dev-secret-change-in-prod
LOG_LEVEL=debug

# ==============================================================================
# Database Configuration
# ==============================================================================
DATABASE_URL=postgresql://user:password@postgres:5432/journaling_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=journaling_db

# ==============================================================================
# Redis Configuration
# ==============================================================================
REDIS_URL=redis://redis:6379

# ==============================================================================
# MinIO / S3-Compatible Object Storage
# ==============================================================================
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=journals
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ==============================================================================
# Analysis Service Configuration
# ==============================================================================
ANALYSIS_API_URL=http://analysis:8000
ANALYSIS_CALLBACK_URL=http://api:3000/api/journals

# ==============================================================================
# Python Analysis Environment
# ==============================================================================
PYTHONUNBUFFERED=1
PYTHON_LOG_LEVEL=debug

# Speech-to-Text (Whisper)
WHISPER_MODEL=tiny
WHISPER_MODEL_ID=openai/whisper-small

# Text Emotion Analysis
TEXT_EMOTION_MODEL_ID=joeddav/xlm-roberta-large-xnli

# Audio Emotion Analysis
AUDIO_EMOTION_MODEL_ID=ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition

# Model Cache Directories
TORCH_HOME=/tmp/torch-models
HF_HOME=/tmp/hf-models

# ==============================================================================
# HuggingFace Integration (Optional - for LLM recommendations)
# ==============================================================================
# HF_API_TOKEN is required when using Hugging Face hosted inference.
# If HF_INFERENCE_URL is empty, the API uses router.huggingface.co with HF_TEXT_GEN_MODEL.
HF_API_TOKEN=
HF_TEXT_GEN_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_INFERENCE_URL=
