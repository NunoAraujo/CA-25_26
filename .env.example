# Frontend Environment
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_ENV=development

# Node.js API Environment
NODE_ENV=development
DATABASE_URL=postgresql://user:password@postgres:5432/journaling_db
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=journals
ANALYSIS_API_URL=http://analysis:8000
ANALYSIS_CALLBACK_URL=http://api:3000/api/journals
JWT_SECRET=dev-secret-change-in-prod
LOG_LEVEL=debug
PORT=3000

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=journaling_db

# Python Analysis Environment
PYTHONUNBUFFERED=1
PYTHON_LOG_LEVEL=debug
WHISPER_MODEL=tiny
TORCH_HOME=/tmp/torch-models
HF_HOME=/tmp/hf-models

# MinIO (shared)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Tooling UI Ports
PGADMIN_PORT=5051

# Redis (shared)
REDIS_HOST=redis
REDIS_PORT=6379
